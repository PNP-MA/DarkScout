# Generated by Cargo
# will have compiled files and executables
target/
debug/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# DarkScout is an executable, so we SHOULD typically commit Cargo.lock for reproducibility.
# However, if the user prefers it ignored, I'll keep it for now but note it.
# Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Environment variables (secrets)
.env
.env.local
.env.*.local

# DarkScout Output
output/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
